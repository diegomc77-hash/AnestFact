    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    },
    "enctype": "multipart/form-data",
    "files": [
      {
        "name": "file",
        "accept": [
          "image/*",
          "application/pdf"
        ]
      }
    ]
  }
