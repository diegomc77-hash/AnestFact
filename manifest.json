{
  "name": "AnesFact v6",
  "short_name": "AnesFact",
  "description": "App de anestesiología - Dra. Huerta ADAARC",
  "start_url": "/AnestFact/",
  "display": "standalone",
  "background_color": "#0D1117",
  "theme_color": "#1DB954",
